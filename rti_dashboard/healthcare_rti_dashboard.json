  "dataSources": [
    {
      "kind": "kusto-trident",
      "id": "ds-healthcare-eventhouse",
      "name": "__KQL_DB_NAME__",
      "clusterUri": "__EVENTHOUSE_QUERY_URI__",
      "databaseArtifactId": "__KQL_DB_ID__"
    }
  ],
  "queries": [
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "ds-healthcare-eventhouse"
      },
      "text": "union\n  (claims_events | where event_timestamp > ago(5m) | summarize claims = count()),\n  (adt_events | where event_timestamp > ago(5m) | summarize adt = count()),\n  (rx_events | where event_timestamp > ago(5m) | summarize rx = count()),\n  (fraud_scores | where score_timestamp > ago(5m) | summarize fraud = count()),\n  (care_gap_alerts | where alert_timestamp > ago(5m) | summarize gaps = count()),\n  (highcost_alerts | where alert_timestamp > ago(5m) | summarize highcost = count())\n| summarize\n    claims_5m = sum(claims),\n    adt_events_5m = sum(adt),\n    rx_events_5m = sum(rx),\n    fraud_alerts_5m = sum(fraud),\n    care_gap_alerts_5m = sum(gaps),\n    highcost_alerts_5m = sum(highcost)",
      "id": "q-live-kpis",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
