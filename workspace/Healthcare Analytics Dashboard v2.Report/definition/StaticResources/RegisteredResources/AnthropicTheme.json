{
  "name": "Anthropic Healthcare Theme",
  "dataColors": [
    "#d97757",
    "#6a9bcc",
    "#788c5d",
    "#b0aea5",
    "#e8e6dc",
    "#c4956a",
    "#5a7fa3",
    "#9aad7f",
    "#d4a27f",
    "#3c6e71"
  ],
  "background": "#141413",
  "foreground": "#faf9f5",
  "tableAccent": "#d97757",
  "good": "#788c5d",
  "neutral": "#6a9bcc",
  "bad": "#d97757",
  "maximum": "#d97757",
  "center": "#6a9bcc",
  "minimum": "#788c5d",
  "textClasses": {
    "callout": {
      "fontSize": 28,
      "fontFace": "Segoe UI Semibold",
      "color": "#faf9f5"
    },
    "title": {
      "fontSize": 14,
      "fontFace": "Segoe UI Semibold",
      "color": "#faf9f5"
    },
    "header": {
      "fontSize": 12,
      "fontFace": "Segoe UI Semibold",
      "color": "#faf9f5"
    },
    "label": {
      "fontSize": 10,
      "fontFace": "Segoe UI",
      "color": "#b0aea5"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "color": {"solid": {"color": "#1e1e1d"}},
            "transparency": 0
          }
        ],
        "border": [
          {
            "color": {"solid": {"color": "#e8e6dc"}},
            "show": false
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": {"solid": {"color": "#faf9f5"}},
            "fontSize": 12,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "subTitle": [
          {
            "show": true,
            "fontColor": {"solid": {"color": "#b0aea5"}},
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ],
        "padding": [
          {
            "top": 8,
            "right": 12,
            "bottom": 8,
            "left": 12
          }
        ],
        "lockAspect": [{"show": false}],
        "dropShadow": [{"show": false}],
        "visualTooltip": [
          {
            "type": {"value": "Default"}
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": {"solid": {"color": "#141413"}},
            "transparency": 0
          }
        ],
        "wallpaper": [
          {
            "color": {"solid": {"color": "#141413"}},
            "transparency": 0
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": {"solid": {"color": "#faf9f5"}},
            "fontSize": 24,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "categoryLabels": [
          {
            "show": true,
            "color": {"solid": {"color": "#b0aea5"}},
            "fontSize": 10
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "items": [
          {
            "fontColor": {"solid": {"color": "#faf9f5"}},
            "background": {"solid": {"color": "#1e1e1d"}}
          }
        ],
        "header": [
          {
            "fontColor": {"solid": {"color": "#faf9f5"}}
          }
        ]
      }
    },
    "tableEx": {
      "*": {
        "grid": [
          {
            "gridVertical": true,
            "gridHorizontal": true,
            "gridVerticalColor": {"solid": {"color": "#2a2a29"}},
            "gridHorizontalColor": {"solid": {"color": "#2a2a29"}},
            "rowPadding": 4
          }
        ],
        "columnHeaders": [
          {
            "fontColor": {"solid": {"color": "#faf9f5"}},
            "backColor": {"solid": {"color": "#2a2a29"}},
            "fontSize": 10,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "values": [
          {
            "fontColor": {"solid": {"color": "#b0aea5"}},
            "backColor": {"solid": {"color": "#1e1e1d"}},
            "fontSize": 10
          }
        ]
      }
    }
  }
}
