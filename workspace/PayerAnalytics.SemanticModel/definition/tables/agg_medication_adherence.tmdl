table agg_medication_adherence
	lineageTag: c10d0001-0001-0001-0001-000000000001
	sourceLineageTag: [dbo].[agg_medication_adherence]

	measure 'Adherent Rate' =
			VAR _num = CALCULATE(COUNTROWS(agg_medication_adherence), agg_medication_adherence[adherence_category] = "Adherent")
			VAR _den = COUNTROWS(agg_medication_adherence)
			RETURN DIVIDE(_num, _den)
		lineageTag: c10d0001-0001-0001-0001-000000000051

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Avg PDC Score' = AVERAGE(agg_medication_adherence[pdc_score])
		lineageTag: c10d0001-0001-0001-0001-000000000052

		annotation PBI_FormatHint = {"isGeneralNumber":true}

