/// Pre-aggregated medication adherence per (patient, medication, measurement period). pdc_score is the Proportion
/// of Days Covered; adherent at >= 0.80.
table agg_medication_adherence
	lineageTag: c10d0001-0001-0001-0001-000000000001
	sourceLineageTag: [dbo].[agg_medication_adherence]

	/// Percentage of patient-medication rows where adherence_category = 'Adherent' (PDC >= 0.80).
	measure 'Adherent Rate' =
			VAR _num = CALCULATE(COUNTROWS(agg_medication_adherence), agg_medication_adherence[adherence_category] = "Adherent")
			VAR _den = COUNTROWS(agg_medication_adherence)
			RETURN DIVIDE(_num, _den)
		lineageTag: c10d0001-0001-0001-0001-000000000051

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Average Proportion of Days Covered across patient-medication rows. Range 0-1; >= 0.80 is adherent.
	measure 'Avg PDC Score' = AVERAGE(agg_medication_adherence[pdc_score])
		lineageTag: c10d0001-0001-0001-0001-000000000052

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Surrogate key for joining to dim_patient. Changes across SCD2 versions.
	column patient_key
		dataType: int64
		formatString: 0
		lineageTag: c10d0001-0001-0001-0001-000000000011
		sourceLineageTag: patient_key
		summarizeBy: none
		sourceColumn: patient_key

		annotation SummarizationSetBy = Automatic

	/// Surrogate key for joining to dim_medication.
	column medication_key
