/// Date dimension with day, week, month, quarter, fiscal year attributes. Use date_key (YYYYMMDD integer) to
/// join.
table dim_date
	lineageTag: c1040001-0001-0001-0001-000000000001
	sourceLineageTag: [dbo].[dim_date]

	/// Date key in YYYYMMDD integer form (e.g. 20250515). Join to dim_date.
	column date_key
		dataType: int64
		formatString: 0
		lineageTag: c1040001-0001-0001-0001-000000000011
		sourceLineageTag: date_key
		summarizeBy: none
		sourceColumn: date_key

		annotation SummarizationSetBy = Automatic

	/// Calendar date (date type).
	column full_date
		dataType: dateTime
		formatString: General Date
		lineageTag: c1040001-0001-0001-0001-000000000012
		sourceLineageTag: full_date
		summarizeBy: none
		sourceColumn: full_date

		annotation SummarizationSetBy = Automatic

	/// ISO weekday number (1=Monday … 7=Sunday).
	column day_of_week
		dataType: int64
		formatString: 0
		lineageTag: c1040001-0001-0001-0001-000000000013
		sourceLineageTag: day_of_week
		summarizeBy: none
		sourceColumn: day_of_week

		annotation SummarizationSetBy = Automatic

	/// Weekday name (Monday, Tuesday, …).
	column day_name
		dataType: string
		lineageTag: c1040001-0001-0001-0001-000000000014
		sourceLineageTag: day_name
		summarizeBy: none
		sourceColumn: day_name

		annotation SummarizationSetBy = Automatic

	/// Day of month (1-31).
	column day_of_month
		dataType: int64
		formatString: 0
		lineageTag: c1040001-0001-0001-0001-000000000015
		sourceLineageTag: day_of_month
		summarizeBy: none
		sourceColumn: day_of_month

		annotation SummarizationSetBy = Automatic

	/// Day of year (1-366).
	column day_of_year
		dataType: int64
		formatString: 0
		lineageTag: c1040001-0001-0001-0001-000000000016
		sourceLineageTag: day_of_year
		summarizeBy: none
		sourceColumn: day_of_year

		annotation SummarizationSetBy = Automatic

	/// ISO week number (1-53).
	column week_of_year
		dataType: int64
		formatString: 0
		lineageTag: c1040001-0001-0001-0001-000000000017
		sourceLineageTag: week_of_year
		summarizeBy: none
		sourceColumn: week_of_year

		annotation SummarizationSetBy = Automatic

	/// Month number (1-12).
	column month_number
		dataType: int64
		formatString: 0
		lineageTag: c1040001-0001-0001-0001-000000000018
		sourceLineageTag: month_number
		summarizeBy: none
		sourceColumn: month_number

		annotation SummarizationSetBy = Automatic

	/// Month name (January, February, …).
	column month_name
		dataType: string
		lineageTag: c1040001-0001-0001-0001-000000000019
		sourceLineageTag: month_name
		summarizeBy: none
		sourceColumn: month_name

		annotation SummarizationSetBy = Automatic

	/// Calendar quarter (Q1-Q4).
	column quarter
		dataType: int64
		formatString: 0
		lineageTag: c1040001-0001-0001-0001-00000000001a
		sourceLineageTag: quarter
		summarizeBy: none
		sourceColumn: quarter

		annotation SummarizationSetBy = Automatic

	/// Calendar year (4-digit).
	column year
		dataType: int64
		formatString: 0
		lineageTag: c1040001-0001-0001-0001-00000000001b
		sourceLineageTag: year
		summarizeBy: none
		sourceColumn: year

		annotation SummarizationSetBy = Automatic

	/// 1 = Saturday or Sunday; 0 otherwise.
	column is_weekend
		dataType: int64
		formatString: 0
		lineageTag: c1040001-0001-0001-0001-00000000001c
		sourceLineageTag: is_weekend
		summarizeBy: none
		sourceColumn: is_weekend

		annotation SummarizationSetBy = Automatic

	/// 1 = US federal holiday; 0 otherwise.
	column is_holiday
		dataType: int64
		formatString: 0
		lineageTag: c1040001-0001-0001-0001-00000000001d
		sourceLineageTag: is_holiday
		summarizeBy: none
		sourceColumn: is_holiday

		annotation SummarizationSetBy = Automatic

	/// Fiscal year aligned to the organization's reporting calendar.
	column fiscal_year
		dataType: int64
		formatString: 0
		lineageTag: c1040001-0001-0001-0001-00000000001e
		sourceLineageTag: fiscal_year
		summarizeBy: none
		sourceColumn: fiscal_year

		annotation SummarizationSetBy = Automatic

	/// Fiscal quarter within fiscal year.
	column fiscal_quarter
		dataType: int64
		formatString: 0
		lineageTag: c1040001-0001-0001-0001-00000000001f
		sourceLineageTag: fiscal_quarter
		summarizeBy: none
		sourceColumn: fiscal_quarter

		annotation SummarizationSetBy = Automatic

	partition dim_date = entity
		mode: directLake
		source
			entityName: dim_date
			expressionSource: 'DirectLake - lh_gold_curated'
