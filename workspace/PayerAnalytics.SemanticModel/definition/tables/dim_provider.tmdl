/// Provider master dimension. One row per clinician (NPI). Use display_name for search and specialty / department
/// for grouping.
table dim_provider
	lineageTag: c1020001-0001-0001-0001-000000000001
	sourceLineageTag: [dbo].[dim_provider]

	/// Provider business key.
	column provider_id
		dataType: string
		lineageTag: c1020001-0001-0001-0001-000000000011
		sourceLineageTag: provider_id
		summarizeBy: none
		sourceColumn: provider_id

		annotation SummarizationSetBy = Automatic

	/// Provider first name.
	column first_name
		dataType: string
		lineageTag: c1020001-0001-0001-0001-000000000012
		sourceLineageTag: first_name
		summarizeBy: none
		sourceColumn: first_name

		annotation SummarizationSetBy = Automatic

	/// Provider last name.
	column last_name
		dataType: string
		lineageTag: c1020001-0001-0001-0001-000000000013
		sourceLineageTag: last_name
		summarizeBy: none
		sourceColumn: last_name

		annotation SummarizationSetBy = Automatic

	/// Provider display name (preferred field for name search).
	column display_name
		dataType: string
		lineageTag: c1020001-0001-0001-0001-000000000014
		sourceLineageTag: display_name
		summarizeBy: none
		sourceColumn: display_name

		annotation SummarizationSetBy = Automatic

	/// 10-digit National Provider Identifier.
	column npi_number
		dataType: string
		lineageTag: c1020001-0001-0001-0001-000000000015
		sourceLineageTag: npi_number
		summarizeBy: none
		sourceColumn: npi_number

		annotation SummarizationSetBy = Automatic

	/// Clinical specialty (Cardiology, Endocrinology, Internal Medicine, ...).
	column specialty
		dataType: string
		lineageTag: c1020001-0001-0001-0001-000000000016
		sourceLineageTag: specialty
		summarizeBy: none
		sourceColumn: specialty

		annotation SummarizationSetBy = Automatic

	/// Hospital department or service line.
	column department
		dataType: string
		lineageTag: c1020001-0001-0001-0001-000000000017
		sourceLineageTag: department
		summarizeBy: none
		sourceColumn: department

		annotation SummarizationSetBy = Automatic

	/// Business key.
	column facility_id
		dataType: string
		lineageTag: c1020001-0001-0001-0001-000000000018
		sourceLineageTag: facility_id
		summarizeBy: none
		sourceColumn: facility_id

		annotation SummarizationSetBy = Automatic

	/// 1 = entity is active and selectable; 0 = retired.
	column is_active
		dataType: int64
		formatString: 0
		lineageTag: c1020001-0001-0001-0001-000000000019
		sourceLineageTag: is_active
		summarizeBy: none
		sourceColumn: is_active

		annotation SummarizationSetBy = Automatic

	/// Surrogate key for joining to dim_provider.
	column provider_key
		dataType: int64
		formatString: 0
		lineageTag: c1020001-0001-0001-0001-00000000001a
		sourceLineageTag: provider_key
		summarizeBy: none
		sourceColumn: provider_key

		annotation SummarizationSetBy = Automatic

	/// SCD2 flag — 1 = latest version of this entity; 0 = historical.
	column is_current
		dataType: int64
		formatString: 0
		lineageTag: c1020001-0001-0001-0001-00000000001b
		sourceLineageTag: is_current
		summarizeBy: none
		sourceColumn: is_current

		annotation SummarizationSetBy = Automatic

	/// ETL load audit timestamp. Internal — hide from end users.
	column _load_timestamp
		dataType: dateTime
		formatString: General Date
		lineageTag: c1020001-0001-0001-0001-00000000001c
		sourceLineageTag: _load_timestamp
		summarizeBy: none
		sourceColumn: _load_timestamp

		annotation SummarizationSetBy = Automatic

	partition dim_provider = entity
		mode: directLake
		source
			entityName: dim_provider
			expressionSource: 'DirectLake - lh_gold_curated'
