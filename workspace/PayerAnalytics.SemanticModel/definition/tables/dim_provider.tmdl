/// Provider master dimension. One row per clinician (NPI). Use display_name for search and specialty / department
/// for grouping.
table dim_provider
	lineageTag: 5b5c8f85-00ba-4c38-b380-b53736945859
	sourceLineageTag: [dbo].[dim_provider]

	/// Provider business key.
	column provider_id
		dataType: string
		lineageTag: 8e41082b-bb4e-4987-b207-03228c0e4b29
		sourceLineageTag: provider_id
		summarizeBy: none
		sourceColumn: provider_id

		annotation SummarizationSetBy = Automatic

	/// Provider first name.
	column first_name
		dataType: string
		lineageTag: 67ae321a-df15-418e-87cf-213c15a2a9c5
		sourceLineageTag: first_name
		summarizeBy: none
		sourceColumn: first_name

		annotation SummarizationSetBy = Automatic

	/// Provider last name.
	column last_name
		dataType: string
		lineageTag: fe8348a2-5f92-4f9c-a19a-2c064b699491
		sourceLineageTag: last_name
		summarizeBy: none
		sourceColumn: last_name

		annotation SummarizationSetBy = Automatic

	/// Provider display name (preferred field for name search).
	column display_name
		dataType: string
		lineageTag: 4babf0ac-637e-429a-8fbe-c968eab77dfb
		sourceLineageTag: display_name
		summarizeBy: none
		sourceColumn: display_name

		annotation SummarizationSetBy = Automatic

	/// 10-digit National Provider Identifier.
	column npi_number
		dataType: string
		lineageTag: 53d8f41b-1dcc-4a37-868b-95499166189e
		sourceLineageTag: npi_number
		summarizeBy: none
		sourceColumn: npi_number

		annotation SummarizationSetBy = Automatic

	/// Clinical specialty (Cardiology, Endocrinology, Internal Medicine, ...).
	column specialty
		dataType: string
		lineageTag: 6727c1bf-6d55-4d3c-97ed-a331b8fb6c02
		sourceLineageTag: specialty
		summarizeBy: none
		sourceColumn: specialty

