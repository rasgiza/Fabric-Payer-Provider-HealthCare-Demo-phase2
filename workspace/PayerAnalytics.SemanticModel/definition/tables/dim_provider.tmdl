	/// Business key.
	column facility_id
		dataType: string
		lineageTag: bbd2d1ad-8829-44c0-82db-0658c9276350
		sourceLineageTag: facility_id
		summarizeBy: none
		sourceColumn: facility_id

		annotation SummarizationSetBy = Automatic

	/// 1 = entity is active and selectable; 0 = retired.
	column is_active
		dataType: int64
		formatString: 0
		lineageTag: 69b70e7a-3aec-4203-9b53-2e30d29fa8ed
		sourceLineageTag: is_active
		summarizeBy: none
		sourceColumn: is_active

		annotation SummarizationSetBy = Automatic

	/// Surrogate key for joining to dim_provider.
	column provider_key
		isHidden: true
		dataType: int64
		formatString: 0
		lineageTag: 72e353c2-910d-4323-8bee-d9214355f200
		sourceLineageTag: provider_key
		summarizeBy: none
		sourceColumn: provider_key

		annotation SummarizationSetBy = Automatic

	/// SCD2 flag — 1 = latest version of this entity; 0 = historical.
	column is_current
		dataType: int64
		formatString: 0
		lineageTag: f065289c-a84d-4eae-8670-2ab487da2135
		sourceLineageTag: is_current
		summarizeBy: none
		sourceColumn: is_current

		annotation SummarizationSetBy = Automatic

	/// ETL load audit timestamp. Internal — hide from end users.
	column _load_timestamp
		dataType: dateTime
		formatString: General Date
		lineageTag: 8f0c9f36-6b27-4fb9-a555-2d426f7f9f65
		sourceLineageTag: _load_timestamp
		summarizeBy: none
