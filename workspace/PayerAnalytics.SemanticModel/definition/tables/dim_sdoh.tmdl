/// Social Determinants of Health dimension at the ZIP-code level. Always filter by risk_tier
/// ('High'/'Medium'/'Low'), never by raw social_vulnerability_index.
table dim_sdoh
	lineageTag: c1070001-0001-0001-0001-000000000001
	sourceLineageTag: [dbo].[dim_sdoh]

	/// Surrogate join key.
	column sdoh_key
		dataType: int64
		formatString: 0
		lineageTag: c1070001-0001-0001-0001-000000000011
		sourceLineageTag: sdoh_key
		summarizeBy: none
		sourceColumn: sdoh_key

		annotation SummarizationSetBy = Automatic

	/// 5-digit ZIP code (community).
	column zip_code
		dataType: string
		lineageTag: c1070001-0001-0001-0001-000000000012
		sourceLineageTag: zip_code
		summarizeBy: none
		sourceColumn: zip_code

		annotation SummarizationSetBy = Automatic

	/// State.
	column state
		dataType: string
		lineageTag: c1070001-0001-0001-0001-000000000013
		sourceLineageTag: state
		summarizeBy: none
		sourceColumn: state

		annotation SummarizationSetBy = Automatic

	/// Census poverty rate for the ZIP (0-1).
	column poverty_rate
		dataType: double
		lineageTag: c1070001-0001-0001-0001-000000000014
		sourceLineageTag: poverty_rate
		summarizeBy: none
		sourceColumn: poverty_rate

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// 1 = ZIP designated a food desert; 0 otherwise.
	column food_desert_flag
		dataType: int64
		formatString: 0
		lineageTag: c1070001-0001-0001-0001-000000000015
		sourceLineageTag: food_desert_flag
		summarizeBy: none
		sourceColumn: food_desert_flag

		annotation SummarizationSetBy = Automatic

	/// Transportation access score (higher = better access).
	column transportation_score
		dataType: double
		lineageTag: c1070001-0001-0001-0001-000000000016
		sourceLineageTag: transportation_score
		summarizeBy: none
		sourceColumn: transportation_score

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Rate (0-1).
	column housing_instability_rate
		dataType: double
		lineageTag: c1070001-0001-0001-0001-000000000017
		sourceLineageTag: housing_instability_rate
		summarizeBy: none
		sourceColumn: housing_instability_rate

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Census uninsured rate for the ZIP (0-1).
	column uninsured_rate
		dataType: double
		lineageTag: c1070001-0001-0001-0001-000000000018
		sourceLineageTag: uninsured_rate
		summarizeBy: none
		sourceColumn: uninsured_rate

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Percentage (0-1 unless otherwise noted).
	column broadband_access_pct
		dataType: double
		lineageTag: c1070001-0001-0001-0001-000000000019
		sourceLineageTag: broadband_access_pct
		summarizeBy: none
		sourceColumn: broadband_access_pct

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Median of the underlying measure.
	column median_household_income
		dataType: int64
		formatString: 0
		lineageTag: c1070001-0001-0001-0001-00000000001a
		sourceLineageTag: median_household_income
		summarizeBy: none
		sourceColumn: median_household_income

		annotation SummarizationSetBy = Automatic

	/// Population.
	column population
		dataType: int64
		formatString: 0
		lineageTag: c1070001-0001-0001-0001-00000000001b
		sourceLineageTag: population
		summarizeBy: none
		sourceColumn: population

		annotation SummarizationSetBy = Automatic

	/// SVI 0-1 (this dataset 0.05-0.53). Do NOT filter on this directly; use risk_tier.
	column social_vulnerability_index
		dataType: double
		lineageTag: c1070001-0001-0001-0001-00000000001c
		sourceLineageTag: social_vulnerability_index
		summarizeBy: none
		sourceColumn: social_vulnerability_index

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// SDOH risk tier: High (SVI >= 0.30), Medium (0.15-0.30), Low (< 0.15). Always filter SDOH by this string, NOT
	/// the raw SVI.
	column risk_tier
		dataType: string
		lineageTag: c1070001-0001-0001-0001-00000000001d
		sourceLineageTag: risk_tier
		summarizeBy: none
		sourceColumn: risk_tier

		annotation SummarizationSetBy = Automatic

	/// 1 = entity is active and selectable; 0 = retired.
	column is_active
		dataType: int64
		formatString: 0
		lineageTag: c1070001-0001-0001-0001-00000000001e
		sourceLineageTag: is_active
		summarizeBy: none
		sourceColumn: is_active

		annotation SummarizationSetBy = Automatic

	/// ETL load audit timestamp. Internal — hide from end users.
	column _load_timestamp
		dataType: dateTime
		formatString: General Date
		lineageTag: c1070001-0001-0001-0001-00000000001f
		sourceLineageTag: _load_timestamp
		summarizeBy: none
		sourceColumn: _load_timestamp

		annotation SummarizationSetBy = Automatic

	partition dim_sdoh = entity
		mode: directLake
		source
			entityName: dim_sdoh
			expressionSource: 'DirectLake - lh_gold_curated'
