/// Prior-authorization fact. One row per auth request with status, decision date, and turnaround time.
table fact_authorization
	lineageTag: c1110001-0001-0001-0001-000000000001
	sourceLineageTag: [dbo].[fact_authorization]

	/// Measure: total auths.
	measure 'Total Auths' = COUNTROWS(fact_authorization)
		formatString: 0
		lineageTag: c1110001-0001-0001-0001-000000000011

	/// Measure: pa approval rate.
	measure 'PA Approval Rate' =
			VAR _approved = CALCULATE(COUNTROWS(fact_authorization), fact_authorization[auth_outcome] = "Approved")
			VAR _decided = CALCULATE(COUNTROWS(fact_authorization), fact_authorization[auth_outcome] <> BLANK())
			RETURN DIVIDE(_approved, _decided)
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: c1110001-0001-0001-0001-000000000012

	/// Measure: pa denial rate.
	measure 'PA Denial Rate' =
			VAR _denied = CALCULATE(COUNTROWS(fact_authorization), fact_authorization[auth_outcome] = "Denied")
			VAR _decided = CALCULATE(COUNTROWS(fact_authorization), fact_authorization[auth_outcome] <> BLANK())
			RETURN DIVIDE(_denied, _decided)
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: c1110001-0001-0001-0001-000000000013

	/// Measure: avg decision tat (hrs).
	measure 'Avg Decision TAT (hrs)' = AVERAGE(fact_authorization[decision_tat_hours])
		formatString: 0.0
		lineageTag: c1110001-0001-0001-0001-000000000014

	/// Business key.
	column auth_id
		dataType: string
		lineageTag: c1110001-0001-0001-0001-000000000021
		sourceLineageTag: auth_id
		summarizeBy: none
		sourceColumn: auth_id
		annotation SummarizationSetBy = Automatic

	/// Surrogate join key.
	column auth_key
		dataType: int64
		formatString: 0
		lineageTag: c1110001-0001-0001-0001-000000000022
		sourceLineageTag: auth_key
		summarizeBy: none
		sourceColumn: auth_key
		annotation SummarizationSetBy = Automatic

	/// Surrogate join key.
	column submit_date_key
		dataType: int64
		formatString: 0
		lineageTag: c1110001-0001-0001-0001-000000000023
		sourceLineageTag: submit_date_key
		summarizeBy: none
		sourceColumn: submit_date_key
		annotation SummarizationSetBy = Automatic

	/// Surrogate join key.
	column decision_date_key
		dataType: int64
		formatString: 0
		lineageTag: c1110001-0001-0001-0001-000000000024
		sourceLineageTag: decision_date_key
		summarizeBy: none
		sourceColumn: decision_date_key
		annotation SummarizationSetBy = Automatic

	/// Surrogate join key.
	column member_key
		dataType: int64
		formatString: 0
		lineageTag: c1110001-0001-0001-0001-000000000025
		sourceLineageTag: member_key
		summarizeBy: none
		sourceColumn: member_key
		annotation SummarizationSetBy = Automatic

	/// Surrogate key for joining to dim_provider.
	column provider_key
		dataType: int64
		formatString: 0
		lineageTag: c1110001-0001-0001-0001-000000000026
		sourceLineageTag: provider_key
		summarizeBy: none
		sourceColumn: provider_key
		annotation SummarizationSetBy = Automatic

	/// Surrogate key for joining to dim_payer.
	column payer_key
		dataType: int64
		formatString: 0
		lineageTag: c1110001-0001-0001-0001-000000000027
		sourceLineageTag: payer_key
		summarizeBy: none
		sourceColumn: payer_key
		annotation SummarizationSetBy = Automatic

	/// Business key.
	column claim_id
		dataType: string
		lineageTag: c1110001-0001-0001-0001-000000000028
		sourceLineageTag: claim_id
		summarizeBy: none
		sourceColumn: claim_id
		annotation SummarizationSetBy = Automatic

	/// Cpt code.
	column cpt_code
		dataType: string
		lineageTag: c1110001-0001-0001-0001-000000000029
		sourceLineageTag: cpt_code
		summarizeBy: none
		sourceColumn: cpt_code
		annotation SummarizationSetBy = Automatic

	/// Primary diagnosis code.
	column primary_diagnosis_code
		dataType: string
		lineageTag: c1110001-0001-0001-0001-00000000002a
		sourceLineageTag: primary_diagnosis_code
		summarizeBy: none
		sourceColumn: primary_diagnosis_code
		annotation SummarizationSetBy = Automatic

	/// Auth outcome.
	column auth_outcome
		dataType: string
		lineageTag: c1110001-0001-0001-0001-00000000002b
		sourceLineageTag: auth_outcome
		summarizeBy: none
		sourceColumn: auth_outcome
		annotation SummarizationSetBy = Automatic

	/// Decision tat hours.
	column decision_tat_hours
		dataType: double
		lineageTag: c1110001-0001-0001-0001-00000000002c
		sourceLineageTag: decision_tat_hours
		summarizeBy: average
		sourceColumn: decision_tat_hours
		annotation SummarizationSetBy = Automatic

	/// Auth units requested.
	column auth_units_requested
		dataType: int64
		formatString: 0
		lineageTag: c1110001-0001-0001-0001-00000000002d
		sourceLineageTag: auth_units_requested
		summarizeBy: sum
		sourceColumn: auth_units_requested
		annotation SummarizationSetBy = Automatic

