		lineageTag: c1110001-0001-0001-0001-00000000002e
		sourceLineageTag: auth_units_approved
		summarizeBy: sum
		sourceColumn: auth_units_approved
		annotation SummarizationSetBy = Automatic

	/// ETL load audit timestamp. Internal — hide from end users.
	column _load_timestamp
		dataType: dateTime
		formatString: General Date
		lineageTag: c1110001-0001-0001-0001-00000000002f
		sourceLineageTag: _load_timestamp
		summarizeBy: none
		sourceColumn: _load_timestamp
		annotation SummarizationSetBy = Automatic

	partition fact_authorization = entity
		mode: directLake
		source
			entityName: fact_authorization
			expressionSource: 'DirectLake - lh_gold_curated'
