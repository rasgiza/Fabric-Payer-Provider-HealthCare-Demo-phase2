	/// Percentage (0-1 unless otherwise noted).
	column margin_pct
		dataType: double
		lineageTag: b10d0001-0001-0001-0001-000000000018
		sourceLineageTag: margin_pct
		summarizeBy: average
		sourceColumn: margin_pct

