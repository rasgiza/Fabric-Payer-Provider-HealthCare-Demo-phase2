/// Pre-aggregated revenue and margin by DRG (Diagnosis-Related Group). Used for service-line profitability.
table agg_revenue_by_drg
	lineageTag: b10d0001-0001-0001-0001-000000000001
	sourceLineageTag: [dbo].[agg_revenue_by_drg]

	/// Drg code.
	column drg_code
		dataType: string
		lineageTag: b10d0001-0001-0001-0001-000000000011
		sourceLineageTag: drg_code
		summarizeBy: none
		sourceColumn: drg_code

		annotation SummarizationSetBy = Automatic

	/// Drg description.
	column drg_description
		dataType: string
		lineageTag: b10d0001-0001-0001-0001-000000000012
		sourceLineageTag: drg_description
		summarizeBy: none
		sourceColumn: drg_description

		annotation SummarizationSetBy = Automatic

	/// Count of records in the underlying grain.
	column encounter_count
		dataType: int64
		formatString: 0
		lineageTag: b10d0001-0001-0001-0001-000000000013
		sourceLineageTag: encounter_count
		summarizeBy: sum
		sourceColumn: encounter_count

		annotation SummarizationSetBy = Automatic

	/// Average of the underlying measure across the grain.
	column avg_charges
		dataType: double
		lineageTag: b10d0001-0001-0001-0001-000000000014
		sourceLineageTag: avg_charges
		summarizeBy: average
		sourceColumn: avg_charges

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Average of the underlying measure across the grain.
	column avg_cost_to_deliver
		dataType: double
		lineageTag: b10d0001-0001-0001-0001-000000000015
		sourceLineageTag: avg_cost_to_deliver
		summarizeBy: average
		sourceColumn: avg_cost_to_deliver

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Average of the underlying measure across the grain.
	column avg_expected_reimbursement
		dataType: double
		lineageTag: b10d0001-0001-0001-0001-000000000016
		sourceLineageTag: avg_expected_reimbursement
		summarizeBy: average
		sourceColumn: avg_expected_reimbursement

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Margin per case.
	column margin_per_case
