/// Medication dimension. drug_class and therapeutic_area are the preferred grouping fields; is_chronic flags
/// maintenance medications.
table dim_medication
	lineageTag: b1050001-0001-0001-0001-000000000001
	sourceLineageTag: [dbo].[dim_medication]

	/// Surrogate key for joining to dim_medication.
	column medication_key
		dataType: int64
		formatString: 0
		lineageTag: b1050001-0001-0001-0001-000000000011
		sourceLineageTag: medication_key
		summarizeBy: none
		sourceColumn: medication_key

		annotation SummarizationSetBy = Automatic

	/// RxNorm clinical drug identifier.
	column rxnorm_code
		dataType: string
		lineageTag: b1050001-0001-0001-0001-000000000012
		sourceLineageTag: rxnorm_code
		summarizeBy: none
		sourceColumn: rxnorm_code

		annotation SummarizationSetBy = Automatic

	/// Brand or generic name as dispensed.
	column medication_name
		dataType: string
		lineageTag: b1050001-0001-0001-0001-000000000013
		sourceLineageTag: medication_name
		summarizeBy: none
		sourceColumn: medication_name

		annotation SummarizationSetBy = Automatic

	/// Generic (non-proprietary) name.
	column generic_name
		dataType: string
		lineageTag: b1050001-0001-0001-0001-000000000014
		sourceLineageTag: generic_name
		summarizeBy: none
		sourceColumn: generic_name

		annotation SummarizationSetBy = Automatic

	/// Pharmacological class (e.g. Statin, ACE Inhibitor, Biguanide).
	column drug_class
		dataType: string
		lineageTag: b1050001-0001-0001-0001-000000000015
		sourceLineageTag: drug_class
		summarizeBy: none
		sourceColumn: drug_class

		annotation SummarizationSetBy = Automatic

	/// Therapeutic area (Cardiovascular, Endocrine, Respiratory, ...).
	column therapeutic_area
		dataType: string
		lineageTag: b1050001-0001-0001-0001-000000000016
		sourceLineageTag: therapeutic_area
		summarizeBy: none
		sourceColumn: therapeutic_area

		annotation SummarizationSetBy = Automatic

	/// Route of administration (Oral, IV, Topical, ...).
	column route
		dataType: string
		lineageTag: b1050001-0001-0001-0001-000000000017
		sourceLineageTag: route
		summarizeBy: none
		sourceColumn: route

		annotation SummarizationSetBy = Automatic

	/// Dosage form (Tablet, Capsule, Solution, ...).
	column form
		dataType: string
		lineageTag: b1050001-0001-0001-0001-000000000018
		sourceLineageTag: form
		summarizeBy: none
		sourceColumn: form

		annotation SummarizationSetBy = Automatic

	/// Drug strength as labeled (e.g. '500 mg').
	column strength
		dataType: string
		lineageTag: b1050001-0001-0001-0001-000000000019
		sourceLineageTag: strength
		summarizeBy: none
		sourceColumn: strength

		annotation SummarizationSetBy = Automatic

	/// 1 = chronic / maintenance condition or medication; 0 = acute.
	column is_chronic
		dataType: int64
		formatString: 0
		lineageTag: b1050001-0001-0001-0001-00000000001a
		sourceLineageTag: is_chronic
		summarizeBy: none
		sourceColumn: is_chronic

		annotation SummarizationSetBy = Automatic

	/// 1 = entity is active and selectable; 0 = retired.
	column is_active
		dataType: int64
		formatString: 0
		lineageTag: b1050001-0001-0001-0001-00000000001b
		sourceLineageTag: is_active
		summarizeBy: none
		sourceColumn: is_active

		annotation SummarizationSetBy = Automatic

	/// ETL load audit timestamp. Internal — hide from end users.
	column _load_timestamp
		dataType: dateTime
		formatString: General Date
		lineageTag: b1050001-0001-0001-0001-00000000001c
		sourceLineageTag: _load_timestamp
		summarizeBy: none
		sourceColumn: _load_timestamp

		annotation SummarizationSetBy = Automatic

	partition dim_medication = entity
		mode: directLake
		source
			entityName: dim_medication
			expressionSource: 'DirectLake - lh_gold_curated'
