{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/dataAgent/definition/dataSource/1.0.0/schema.json",
  "artifactId": "a1000001-0001-0001-0001-000000000004",
  "workspaceId": "00000000-0000-0000-0000-000000000000",
  "dataSourceInstructions": "This lakehouse contains 16 Delta tables in a payer-focused healthcare analytics star schema (Gold layer). Includes payer-exclusive tables: dim_payer, agg_days_in_ar, agg_appeal_outcomes.\n\nQUICK REFERENCE:\n- \"denial rate/reasons/denied\" -> fact_claim JOIN dim_payer\n- \"appeal outcomes/recovery\" -> agg_appeal_outcomes\n- \"days in AR/payment timeliness\" -> agg_days_in_ar\n- \"collection rate\" -> fact_claim (paid/billed)\n- \"rx cost by payer/copay\" -> fact_prescription JOIN dim_payer\n- \"PMPM/charges\" -> fact_encounter\n- \"readmission rate/trend\" -> agg_readmission_by_date\n- \"adherence/PDC\" -> agg_medication_adherence\n- \"diagnosis/ICD\" -> fact_diagnosis JOIN dim_diagnosis\n- \"patient details\" -> dim_patient WHERE is_current = 1\n- \"provider network\" -> dim_provider (minimal columns)\n- \"SDOH/vulnerability\" -> dim_sdoh JOIN dim_patient ON zip_code\n- \"DRG revenue\" -> agg_revenue_by_drg\n- \"payer mix/payer details\" -> dim_payer\n\nTABLE SCHEMAS:\n\nfact_claim: claim_key (PK), claim_id, patient_key (FK), provider_key (FK), payer_key (FK), encounter_key (FK), facility_key, claim_date_key (FK), payment_date_key (FK), claim_type, claim_status (Approved|Denied|Pending), billed_amount (FLOAT $), allowed_amount (FLOAT $), paid_amount (FLOAT $), denial_flag (INT 0/1), denial_risk_score (FLOAT), denial_risk_category (High|Medium|Low), primary_denial_reason, recommended_action, days_to_payment (INT), net_collection_rate (FLOAT), appeal_date (DATETIME), appeal_outcome (Won|Lost|Pending|blank), appeal_amount_recovered (FLOAT $)\n\nfact_encounter: encounter_key (PK), encounter_id, patient_key (FK), provider_key (FK), encounter_date_key (FK), discharge_date_key (FK), facility_key, encounter_type (Inpatient|Outpatient|Emergency|Observation|Telehealth), admission_type, discharge_disposition, length_of_stay (INT), total_charges (FLOAT $), total_cost (FLOAT $), readmission_flag (INT 0/1), readmission_risk_score (FLOAT 0.0-1.0), readmission_risk_category (High|Medium|Low), drg_code, drg_description, drg_weight (FLOAT), expected_reimbursement (FLOAT $)\n\nfact_prescription: prescription_key (PK), prescription_id, patient_key (FK), provider_key (FK), payer_key (FK), medication_key (FK), encounter_key (FK), fill_date_key (FK), facility_key, fill_number, days_supply, quantity_dispensed, refills_authorized, is_generic (INT 0/1), is_chronic_medication (INT 0/1), total_cost (FLOAT $), payer_paid (FLOAT $), patient_copay (FLOAT $), pharmacy_type\n\nfact_diagnosis: fact_diagnosis_key (PK), diagnosis_id, encounter_key (FK), diagnosis_date_key (FK), patient_key (FK), diagnosis_key (FK), facility_key, icd_code, diagnosis_sequence, diagnosis_type (principal|secondary), present_on_admission (Y/N/U)\n\ndim_payer: payer_key (PK), payer_id, payer_name, payer_type (Commercial|Government), plan_type, state, network_size (Large|Medium|Small), avg_reimbursement_pct (FLOAT), is_active (INT 0/1)\n\ndim_patient: patient_key (PK), patient_id, first_name, last_name, date_of_birth, age, age_group, gender, city, state, zip_code, insurance_type, insurance_provider, is_current (INT 0|1 -- ALWAYS FILTER = 1)\n\ndim_provider: provider_key (PK), provider_id, first_name, last_name, display_name, specialty, department, npi_number, facility_id, is_active (INT 0/1), is_current (INT 0|1). NOTE: Minimal \u00e2\u20ac\u201d no RVU, panel size, or productivity columns.\n\ndim_diagnosis: diagnosis_key (PK), icd_code, icd_description, icd_category, is_chronic (INT 0/1)\n\ndim_medication: medication_key (PK), rxnorm_code, medication_name, generic_name, drug_class, therapeutic_area, route, form, strength, is_chronic (INT 0/1), is_active (INT 0/1)\n\ndim_sdoh: sdoh_key (PK), zip_code, state, risk_tier (High|Medium|Low), poverty_rate, food_desert_flag (INT 0/1), transportation_score, housing_instability_rate, uninsured_rate, broadband_access_pct, median_household_income, population, social_vulnerability_index\n\ndim_date: date_key (PK INT YYYYMMDD), full_date, year, quarter, month_number, month_name, day_of_month, day_of_week, day_name, is_weekend, is_holiday, fiscal_year, fiscal_quarter\n\nagg_readmission_by_date: encounter_date_key (FK), encounter_type, total_encounters, actual_readmissions, high_risk_count, medium_risk_count, low_risk_count, avg_risk_score, total_charges, avg_length_of_stay\n\nagg_medication_adherence: patient_key (FK), medication_key (FK), drug_class, therapeutic_area, measurement_period_start, measurement_period_end, total_fills, total_days_supply, days_in_period, covered_days, pdc_score (FLOAT 0.0-1.0), adherence_category (Adherent|Partial|Non-Adherent), total_medication_cost, total_payer_cost, total_patient_cost, gap_days, is_chronic\n\nagg_revenue_by_drg: drg_code, drg_description, encounter_count, avg_charges, avg_cost_to_deliver, avg_expected_reimbursement, margin_per_case, margin_pct\n\nagg_days_in_ar: claim_date_key, payer_name, claim_count (INT), avg_days_to_payment (FLOAT), median_days_to_payment (FLOAT), p90_days_to_payment (FLOAT), avg_net_collection_rate (FLOAT). Use for AR aging trends by payer.\n\nagg_appeal_outcomes: payer_name, denial_reason, appeal_outcome (Won|Lost|Pending), appeal_count (INT), total_amount_recovered (FLOAT $), avg_amount_recovered (FLOAT $). Use for appeal ROI analysis.\n\nSQL RULES:\n1. ALWAYS filter is_current = 1 on dim_patient and dim_provider.\n2. Join dimensions on surrogate keys EXCEPT dim_sdoh on zip_code.\n3. Boolean columns use = 1 for TRUE.\n4. Use NULLIF(denominator, 0) in all rate calculations.\n5. Use CAST(... AS FLOAT) to avoid integer division.\n6. NEVER AVG pre-computed rate columns.\n7. agg_ tables have NO provider_key.\n8. Default TOP 20 for unbounded results.\n9. NEVER add date filters unless user specifies a time period.\n10. For denial by payer, JOIN dim_payer ON payer_key.\n11. Use agg_days_in_ar for AR aging, NOT fact_claim AVG(days_to_payment).\n12. Use agg_appeal_outcomes for appeal success rates, NOT fact_claim.\n\nDENIAL REASON VALUES: \"Prior Auth Required\", \"Not Medically Necessary\", \"Duplicate Claim\", \"Invalid Code\", \"Coverage Expired\", \"Out of Network\", \"Missing Documentation\"\nADHERENCE: pdc_score >= 0.80 Adherent, 0.50-0.80 Partial, < 0.50 Non-Adherent",
  "displayName": "lh_gold_curated",
  "type": "lakehouse_tables",
  "userDescription": "Gold-layer lakehouse with 16 curated payer-focused healthcare tables. Contains claims with payer attribution, appeal outcomes, days-in-AR aging, payer dimensions, prescriptions with cost splits, clinical encounters, and supporting dimension tables.",
